# ──────────────────────────────────────────────
# CDP - Agentic Ad Engine  Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── General ─────────────────────────────────────
LOG_LEVEL=DEBUG
JSON_LOGS=false
SERVICE_NAME=cdp-agentic-ad-engine

# ── Redpanda (Kafka-compatible) ─────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:19093
KAFKA_TOPIC_PLATFORM_A=platform-a-events
KAFKA_TOPIC_PLATFORM_B=platform-b-events
KAFKA_CONSUMER_GROUP=cdp-event-consumer
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:18081

# ── MongoDB ─────────────────────────────────────
# directConnection=true bypasses replica set discovery when running locally
MONGODB_URI=mongodb://localhost:27017/?directConnection=true
MONGODB_DATABASE=cdp
MONGODB_PROFILE_COLLECTION=unified_profiles
MONGODB_EVENT_COLLECTION=raw_events

# ── Qdrant (Vector DB) ──────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_PRODUCTS=products
QDRANT_COLLECTION_INTENTS=intents

# ── MinIO (S3-compatible Data Lake) ────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=cdpadmin
S3_SECRET_ACCESS_KEY=cdpadmin123
S3_REGION=us-east-1
S3_BUCKET_RAW_EVENTS=raw-events
S3_PATH_PREFIX=events

# ── Redis (Caching) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_AD_CACHE_TTL=600

# ── Ollama (Local LLM) ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT=120

# ── LLM Provider Fallback (uncomment for cloud) ─
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ── FastAPI ─────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=1000/minute
API_WORKERS=4
CORS_ORIGINS=*

# ── Identity Resolution ─────────────────────────
UID_PROBABILISTIC_THRESHOLD=0.75
UID_TIME_WINDOW_HOURS=2

# ── Agent Settings ──────────────────────────────
INTENT_PROFILER_MAX_RETRIES=3
PRODUCT_MATCHER_TOP_K=5
AD_CREATIVE_REGENERATE_MINUTES=10

# ── Data Preparation ────────────────────────────
GROUND_TRUTH_OVERLAP_RATIO=0.20
PLATFORM_A_SPLIT_RATIO=0.60
RANDOM_SEED=42

# ── Monitoring / Tracing (optional) ────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# SENTRY_DSN=https://...
